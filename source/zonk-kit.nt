import {
  core.ref {ref},
}

data position {
| _Position(
    cursor: int,
    line: int,
    column: int,
    gap-size: int,
  )
}

data zonk-kit(a) {
| _Zonk-Kit(
    input-stream: string,
    position-ref: ref(position),
    constring: a,
  )
}

define get-constring<c>(k: &zonk-kit(c)) -> &c {
  tie _Zonk-Kit {constring} = k;
  constring
}
